# ============================================
# Crontab 配置示例
# ============================================
# 使用方法：
#   1. 根据实际路径修改脚本路径
#   2. 根据需求调整执行时间
#   3. 执行 crontab -e 将内容添加到定时任务
# ============================================

# 定时任务格式说明：
# ┌───────────── 分钟 (0 - 59)
# │ ┌───────────── 小时 (0 - 23)
# │ │ ┌───────────── 日期 (1 - 31)
# │ │ │ ┌───────────── 月份 (1 - 12)
# │ │ │ │ ┌───────────── 星期 (0 - 7，0和7都表示周日)
# │ │ │ │ │
# * * * * * 要执行的命令

# ============================================
# 方案一：单独执行每个任务（推荐）
# ============================================

# 每天凌晨 2:00 执行采购单数据采集
0 2 * * * cd /opt/apps/pythondata && /opt/apps/pythondata/venv/bin/python -m jobs.purchase_order >> /opt/apps/pythondata/logs/cron_purchase.log 2>&1

# 每天凌晨 3:00 执行运营下单数据采集
0 3 * * * cd /opt/apps/pythondata && /opt/apps/pythondata/venv/bin/python -m jobs.operation_order >> /opt/apps/pythondata/logs/cron_operation.log 2>&1

# 每天凌晨 4:00 执行分析表生成
0 4 * * * cd /opt/apps/pythondata && /opt/apps/pythondata/venv/bin/python -m jobs.analysis_table >> /opt/apps/pythondata/logs/cron_analysis.log 2>&1

# ============================================
# 方案二：使用统一脚本执行所有任务
# ============================================

# 每天凌晨 2:00 执行所有数据采集任务
# 0 2 * * * /opt/apps/pythondata/scripts/run_jobs.sh >> /opt/apps/pythondata/logs/cron_all.log 2>&1

# ============================================
# 方案三：多次执行（适合需要实时性的场景）
# ============================================

# 每天 2:00, 8:00, 14:00, 20:00 执行采购单采集
# 0 2,8,14,20 * * * cd /opt/apps/pythondata && /opt/apps/pythondata/venv/bin/python -m jobs.purchase_order >> /opt/apps/pythondata/logs/cron_purchase.log 2>&1

# 每天 3:00, 9:00, 15:00, 21:00 执行运营下单采集
# 0 3,9,15,21 * * * cd /opt/apps/pythondata && /opt/apps/pythondata/venv/bin/python -m jobs.operation_order >> /opt/apps/pythondata/logs/cron_operation.log 2>&1

# 每天 4:00, 10:00, 16:00, 22:00 执行分析表生成
# 0 4,10,16,22 * * * cd /opt/apps/pythondata && /opt/apps/pythondata/venv/bin/python -m jobs.analysis_table >> /opt/apps/pythondata/logs/cron_analysis.log 2>&1

# ============================================
# 维护任务
# ============================================

# 每周日凌晨 1:00 清理 30 天前的日志
0 1 * * 0 find /opt/apps/pythondata/logs -type f -name "*.log" -mtime +30 -delete

# 每月 1 号凌晨 1:30 清理数据库旧数据（根据实际需求编写脚本）
# 30 1 1 * * /opt/apps/pythondata/scripts/cleanup_database.sh >> /opt/apps/pythondata/logs/cron_cleanup.log 2>&1

# ============================================
# 常用时间配置示例
# ============================================

# 每分钟执行：
# * * * * * command

# 每小时执行：
# 0 * * * * command

# 每天凌晨执行：
# 0 0 * * * command

# 每周一上午 9:00 执行：
# 0 9 * * 1 command

# 每月 1 号凌晨 2:00 执行：
# 0 2 1 * * command

# 工作日每天上午 9:00 执行：
# 0 9 * * 1-5 command

# 每 2 小时执行一次：
# 0 */2 * * * command

# 每 30 分钟执行一次：
# */30 * * * * command

# ============================================
# 注意事项
# ============================================
# 1. 确保所有路径都使用绝对路径
# 2. 使用 >> 追加日志，避免覆盖历史日志
# 3. 2>&1 将错误输出也重定向到日志文件
# 4. 定期检查日志文件，监控任务执行情况
# 5. 如需修改，使用 crontab -e 命令
# 6. 查看当前定时任务：crontab -l
# 7. 删除所有定时任务：crontab -r（谨慎使用）

