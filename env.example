# ===== 环境配置 =====
ENVIRONMENT=production
LOG_LEVEL=INFO
LOG_DIR=logs

# ===== 灵星API配置 =====
LINGXING_HOST=https://openapi.lingxing.com
LINGXING_APP_ID=your_app_id_here
LINGXING_APP_SECRET=your_app_secret_here
LINGXING_PROXY_URL=

# ===== 数据库配置 =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=lingxing
DB_CHARSET=utf8mb4

# ===== 飞书API配置 =====
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# ===== 数据采集配置 =====
COLLECTION_START_DATE=2024-01-01
COLLECTION_PAGE_SIZE=200
COLLECTION_DELAY_SECONDS=1

